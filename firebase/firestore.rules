rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isOwnerEmail() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email == "leoisdabest@yahoo.com";
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    function hasOnlyFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function text(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function optionalText(value, max) {
      return value is string && value.size() <= max;
    }

    function hasContactMethod() {
      return text(request.resource.data.email, 5, 140)
        || text(request.resource.data.phone, 7, 30);
    }

    function hasCommonFields() {
      return hasOnlyFields([
        "requestType",
        "fullName",
        "email",
        "phone",
        "eventType",
        "eventDate",
        "venue",
        "coverageHours",
        "budgetRange",
        "message",
        "needs",
        "preferredContact",
        "source",
        "page",
        "contactName",
        "createdAtClient",
        "createdAtServer"
      ])
      && text(request.resource.data.source, 1, 80)
      && text(request.resource.data.page, 1, 80)
      && text(request.resource.data.contactName, 1, 120)
      && text(request.resource.data.createdAtClient, 10, 60)
      && (request.resource.data.createdAtServer == null || request.resource.data.createdAtServer is timestamp);
    }

    match /quote_requests/{docId} {
      allow create: if hasCommonFields()
        && request.resource.data.requestType == "quote"
        && text(request.resource.data.fullName, 2, 80)
        && text(request.resource.data.email, 5, 140)
        && text(request.resource.data.phone, 7, 30)
        && text(request.resource.data.eventType, 2, 40)
        && text(request.resource.data.eventDate, 8, 40)
        && text(request.resource.data.venue, 2, 180)
        && request.resource.data.coverageHours is number
        && request.resource.data.coverageHours >= 1
        && request.resource.data.coverageHours <= 16
        && text(request.resource.data.budgetRange, 3, 40)
        && optionalText(request.resource.data.message, 2000)
        && request.resource.data.needs is list
        && request.resource.data.needs.size() <= 20
        && request.resource.data.preferredContact in ["phone", "email", "text"];

      allow read, update, delete: if isAdmin();
    }

    match /question_requests/{docId} {
      allow create: if hasCommonFields()
        && request.resource.data.requestType == "questions"
        && text(request.resource.data.fullName, 2, 80)
        && hasContactMethod()
        && text(request.resource.data.message, 2, 2000)
        && optionalText(request.resource.data.eventType, 40)
        && optionalText(request.resource.data.eventDate, 40)
        && optionalText(request.resource.data.venue, 180)
        && request.resource.data.coverageHours is number
        && request.resource.data.coverageHours >= 0
        && request.resource.data.coverageHours <= 16
        && optionalText(request.resource.data.budgetRange, 40)
        && request.resource.data.needs is list
        && request.resource.data.needs.size() <= 20
        && request.resource.data.preferredContact in ["phone", "email", "text"];

      allow read, update, delete: if isAdmin();
    }

    match /estimate_requests/{docId} {
      allow create: if request.resource.data.keys().hasOnly([
          "sessionType",
          "coverageHours",
          "deliverable",
          "month",
          "estimateText",
          "availability",
          "source",
          "page",
          "contactName",
          "createdAtClient",
          "createdAtServer"
        ])
        && text(request.resource.data.sessionType, 2, 40)
        && request.resource.data.coverageHours is number
        && request.resource.data.coverageHours >= 1
        && request.resource.data.coverageHours <= 16
        && text(request.resource.data.deliverable, 2, 40)
        && text(request.resource.data.month, 3, 10)
        && text(request.resource.data.estimateText, 2, 40)
        && text(request.resource.data.availability, 2, 40)
        && text(request.resource.data.source, 1, 80)
        && text(request.resource.data.page, 1, 80)
        && text(request.resource.data.contactName, 1, 120)
        && text(request.resource.data.createdAtClient, 10, 60)
        && (request.resource.data.createdAtServer == null || request.resource.data.createdAtServer is timestamp);

      allow read, update, delete: if isAdmin();
    }

    match /page_views/{docId} {
      allow create: if request.resource.data.keys().hasOnly([
          "page",
          "path",
          "visitorId",
          "referrer",
          "userAgent",
          "screen",
          "createdAtClient",
          "createdAtServer"
        ])
        && text(request.resource.data.page, 1, 80)
        && text(request.resource.data.path, 1, 260)
        && text(request.resource.data.visitorId, 8, 120)
        && optionalText(request.resource.data.referrer, 260)
        && optionalText(request.resource.data.userAgent, 320)
        && text(request.resource.data.screen, 3, 20)
        && text(request.resource.data.createdAtClient, 10, 60)
        && (request.resource.data.createdAtServer == null || request.resource.data.createdAtServer is timestamp);

      allow read, update, delete: if isAdmin();
    }

    match /calendar_events/{docId} {
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasOnly([
          "title",
          "date",
          "startTime",
          "endTime",
          "location",
          "notes",
          "provider",
          "createdBy",
          "createdAtClient",
          "createdAtServer"
        ])
        && text(request.resource.data.title, 2, 160)
        && text(request.resource.data.date, 8, 16)
        && optionalText(request.resource.data.startTime, 12)
        && optionalText(request.resource.data.endTime, 12)
        && optionalText(request.resource.data.location, 180)
        && optionalText(request.resource.data.notes, 4000)
        && request.resource.data.provider in ["google", "ics", "manual"]
        && text(request.resource.data.createdBy, 3, 160)
        && text(request.resource.data.createdAtClient, 10, 60)
        && (request.resource.data.createdAtServer == null || request.resource.data.createdAtServer is timestamp);

      allow read, delete: if isAdmin();
    }

    match /admin_users/{uid} {
      allow read: if isAdmin() || isSelf(uid);

      allow create: if isAdmin()
        || (isSelf(uid)
          && isOwnerEmail()
          && request.resource.data.uid == request.auth.uid
          && text(request.resource.data.email, 5, 140));

      allow update, delete: if isAdmin();
    }
  }
}
